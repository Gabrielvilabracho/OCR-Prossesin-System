# ============================================================
# env.production.example — unified secret/config inventory
# ============================================================
# Copy to env.production or a service-specific .env file and fill values locally.
# Values marked [SECRET] must never be committed.
# ============================================================

# ============================================================
# Supabase (managed — supabase.com)
# ============================================================
SUPABASE_URL=<supabase-url>                               # config
SUPABASE_KEY=<supabase-key>                               # [SECRET]
SUPABASE_PROJECT_REF=<supabase-project-ref>               # config (CLI)
SUPABASE_DB_PASSWORD=<supabase-db-password>               # [SECRET] (for psql)

# ============================================================
# Trigger.dev (managed cloud)
# ============================================================
TRIGGER_PROJECT_REF=<trigger-project-ref>                 # config
TRIGGER_SECRET_KEY=<trigger-secret-key>                   # [SECRET]
TRIGGER_API_URL=https://api.trigger.dev                   # config (optional)

# ============================================================
# n8n (self-hosted, Docker)
# ============================================================
N8N_HOST=n8n.example.com                                  # config
N8N_PROTOCOL=https                                        # config
WEBHOOK_URL=https://n8n.example.com/                      # config
N8N_EDITOR_BASE_URL=https://n8n.example.com               # config
N8N_ENCRYPTION_KEY=<n8n-encryption-key>                   # [SECRET] — CRITICAL, back up
N8N_API_KEY=<n8n-api-key>                                 # [SECRET]
N8N_BASIC_AUTH_ACTIVE=true                                # config
N8N_BASIC_AUTH_USER=<n8n-basic-auth-user>                 # [SECRET]
N8N_BASIC_AUTH_PASSWORD=<n8n-basic-auth-password>         # [SECRET]
DB_TYPE=postgresdb                                        # config
DB_POSTGRESDB_HOST=<postgres-host>                        # config
DB_POSTGRESDB_PORT=5432                                   # config
DB_POSTGRESDB_DATABASE=n8n                                # config
DB_POSTGRESDB_USER=n8n                                    # config
DB_POSTGRESDB_PASSWORD=<postgres-password>                # [SECRET]
GENERIC_TIMEZONE=UTC                                      # config
TZ=UTC                                                    # config

# ============================================================
# AI providers (used by Trigger.dev tasks)
# ============================================================
ANTHROPIC_API_KEY=<anthropic-api-key>                     # [SECRET]
OPENAI_API_KEY=<openai-api-key>                           # [SECRET]

# ============================================================
# Datalab (document intelligence — conversion + extraction)
# Dashboard: https://www.datalab.to/app/keys
# SDK: pip install datalab-python-sdk
# ============================================================
DATALAB_API_KEY=<datalab-api-key>                         # [SECRET]

# ============================================================
# Sample Python AI service
# Python-only invoice processing runtime. Existing service directory names may
# remain during cleanup for compatibility.
# ============================================================
# Base URL of the Python AI service (FastAPI).
# For Docker Compose, use the service name as hostname.
SAMPLE_CLIENT_PYTHON_SERVICE_URL=http://sample-client-ai:8001 # config

# Mistral AI API key — used for OCR + extraction.
MISTRAL_API_KEY=<mistral-api-key>                          # [SECRET]
