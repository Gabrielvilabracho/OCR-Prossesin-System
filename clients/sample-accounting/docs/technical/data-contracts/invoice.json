{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SampleInvoice",
  "description": "Public-safe sample invoice payload for documentation and tests.",
  "type": "object",
  "additionalProperties": false,
  "required": ["invoice_id", "source_type", "supplier_name", "total_amount", "currency"],
  "properties": {
    "invoice_id": {
      "type": "string",
      "format": "uuid",
      "examples": ["00000000-0000-4000-8000-000000000101"]
    },
    "source_type": {
      "type": "string",
      "enum": ["upload", "email", "storage"]
    },
    "source_ref": {
      "type": "string",
      "examples": ["invoices@example.com"]
    },
    "supplier_name": {
      "type": "string",
      "examples": ["Example Supplies Ltd"]
    },
    "supplier_tax_id": {
      "type": "string",
      "examples": ["PT000000001"]
    },
    "total_amount": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]{2}$",
      "examples": ["123.45"]
    },
    "currency": {
      "type": "string",
      "examples": ["EUR"]
    },
    "status": {
      "type": "string",
      "enum": ["received", "extracted", "needs_review", "approved"]
    }
  }
}
