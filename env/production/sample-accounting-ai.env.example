# Sample accounting AI production env example.
# Copy to a local service env file on the deployment host. Do not commit real values.

PORT=8001

# Supabase stays external in Phase 2.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
SUPABASE_STORAGE_BUCKET=<supabase-storage-bucket>

# AI providers / observability.
ANTHROPIC_API_KEY=<anthropic-api-key>
MISTRAL_API_KEY=<mistral-api-key-if-used>
LANGSMITH_API_KEY=<langsmith-api-key>
LANGSMITH_PROJECT=<langsmith-project-name>
SENTRY_DSN=<sentry-dsn>

# Runtime controls.
ENVIRONMENT=production
LOG_LEVEL=info
