# Analytics production env example.
# Optional/protected only. Copy to analytics.env on the VPS. Do not commit real values.

ENVIRONMENT=production
LOG_LEVEL=info

# Supabase stays external in Phase 2.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# Optional monitoring.
SENTRY_DSN=<sentry-dsn>

# Streamlit defaults may be overridden by the container entrypoint if needed.
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
