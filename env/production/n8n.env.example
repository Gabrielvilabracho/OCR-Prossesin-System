# n8n production env example.
# n8n is optional/local-only until productive use is approved.
# Copy to n8n.env on the VPS only if the n8n profile is explicitly enabled.

N8N_HOST=n8n.example.com
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.example.com/

# Placeholder auth values. Do not commit real values.
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=<n8n-user>
N8N_BASIC_AUTH_PASSWORD=<n8n-password>

# Encryption key is required for credential storage.
N8N_ENCRYPTION_KEY=<32-plus-character-random-value>

# Use n8n's internal SQLite data volume in Phase 2 unless a separate decision approves otherwise.
DB_TYPE=sqlite
